# Copy to .env and fill in. .env is git-ignored.

# --- LLM (Anthropic Claude) ---
# Required for the natural-language graph editing features.
ANTHROPIC_API_KEY=

# Model used for ontology mutations. Defaults to a current Claude model.
WEAVE_LLM_MODEL=claude-sonnet-4-6

# --- Backend ---
# Directory where the Oxigraph store is persisted.
WEAVE_DATA_DIR=./data
# Seed a demo ontology on first run (true/false).
WEAVE_SEED_DEMO=true
# CORS origins allowed to call the API (comma separated).
WEAVE_CORS_ORIGINS=http://localhost:5173

# --- Frontend ---
# Base URL the frontend uses to reach the backend.
VITE_API_BASE_URL=http://localhost:8000
