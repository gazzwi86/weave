# next-auth v5 requires a signing secret. Generate with: npx auth secret
AUTH_SECRET=dev-only-change-me

# OIDC provider (dev/test default: mock provider from packages/backend).
# Point at a real Cognito user pool issuer URL in staging/prod -- no code change.
OIDC_ISSUER_URL=http://localhost:9001
OIDC_CLIENT_ID=weave-dev
OIDC_CLIENT_SECRET=dev-secret

# Backend API, called server-side only (never from the browser -- keeps
# CSP connect-src 'self' and avoids CORS).
BACKEND_API_URL=http://localhost:8000
