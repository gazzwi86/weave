# Real backend calls out to the OIDC issuer's JWKS/token endpoints here.
# Points at the mock provider (packages/backend/src/weave_backend/mock_oidc)
# in dev/test -- swap for the real Cognito issuer URL in staging/prod.
OIDC_ISSUER_URL=http://localhost:9001

# Mock OIDC provider's own identity (dev/test only -- this process doesn't
# run in staging/prod, where real Cognito issues tokens instead).
MOCK_OIDC_ISSUER_URL=http://localhost:9001
OIDC_CLIENT_ID=weave-dev

# OTel export target for real (non-test) runs. Unset -> localhost:4317 default.
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317

# AI routing (AC-4) -- only the provider actually configured needs creds.
ANTHROPIC_API_KEY=
AWS_REGION=us-east-1
