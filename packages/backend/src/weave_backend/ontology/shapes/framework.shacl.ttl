# TASK-003 (EPIC-004): framework-level classes, not BPMO kinds -- committed
# via CE-WRITE-1 using a full-IRI `kind` (bypasses `authoring/bpmo.py`'s
# 14-kind guard, same convention planned for `weave:Function`). Deliberately
# excluded from `GET /api/ontology/types` -- `ontology/catalogue.py::list_kinds`
# filters to `BPMO_KINDS` membership (ADR-022), so these two shapes still
# validate here without appearing as guided-form kinds.
weave:BrandStandardShape
    a sh:NodeShape ;
    sh:targetClass weave:BrandStandard ;
    sh:property [
        sh:path weave:contentType ;
        sh:name "Content type" ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:severity sh:Violation ;
        sh:message "Every BrandStandard must have exactly one string contentType."@en ;
    ] ;
    sh:property [
        sh:path weave:effectiveDate ;
        sh:name "Effective date" ;
        sh:datatype xsd:date ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:severity sh:Violation ;
        sh:message "Every BrandStandard must have exactly one effectiveDate."@en ;
    ] ;
    sh:property [
        sh:path weave:owner ;
        sh:name "Owner" ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:severity sh:Violation ;
        sh:message "Every BrandStandard must have exactly one owner."@en ;
    ] ;
    sh:or (
        [ sh:property [ sh:path weave:contentBody ; sh:minCount 1 ; ] ]
        [ sh:property [ sh:path weave:sourceUri ; sh:minCount 1 ; ] ]
    ) ;
    sh:severity sh:Violation ;
    sh:message "A BrandStandard must have either a contentBody or a sourceUri."@en .

weave:VoiceRuleShape
    a sh:NodeShape ;
    sh:targetClass weave:VoiceRule ;
    sh:property [
        sh:path weave:ruleId ;
        sh:name "Rule ID" ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:severity sh:Violation ;
        sh:message "Every VoiceRule must have exactly one string ruleId."@en ;
    ] ;
    sh:property [
        sh:path weave:severity ;
        sh:name "Severity" ;
        sh:datatype xsd:string ;
        # explicit ^^xsd:string (not bare "critical") -- rdflib's Turtle
        # parser gives a plain quoted list literal datatype=None, which
        # fails term-equality against `_to_literal`'s explicit
        # Literal(str, datatype=XSD.string) production data (graph_ops.py).
        sh:in ( "critical"^^xsd:string "normal"^^xsd:string ) ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:severity sh:Violation ;
        sh:message "Every VoiceRule must have severity 'critical' or 'normal'."@en ;
    ] ;
    sh:property [
        # AC-003-05: a human label alone is not a rule -- Build mechanically
        # evaluates `assertion`, so it's required, not conventional.
        sh:path weave:assertion ;
        sh:name "Assertion" ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:severity sh:Violation ;
        sh:message "Every VoiceRule must have a machine-evaluable assertion."@en ;
    ] .
