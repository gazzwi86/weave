# CE-TASK-001: core subset of the framework SHACL shapes, ported from the
# `docs/standards/patterns/semantic-web/shacl-shape.md` pattern (ProcessShape)
# plus two more BPMO kinds (Activity, Goal) to exercise all three SHACL
# severities. TASK-004 AC-004-05 adds the remaining 10 BPMO kinds as
# minimal label-only shapes -- CE-READ-1 (`GET /api/ontology/types`, via
# `ontology/catalogue.py::list_kinds`) introspects this file live, so every
# one of the 13 BPMO kinds (`authoring/bpmo.py::BPMO_KINDS`) needs a shape
# here to appear as a guided-form option. Lives in `urn:weave:g:framework`
# (loaded at startup).
@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix weave: <https://weave.io/ontology/> .

weave:ProcessShape
    a sh:NodeShape ;
    sh:targetClass weave:Process ;
    sh:property [
        sh:path weave:label ;
        sh:name "Label" ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:severity sh:Violation ;
        sh:message "Every Process must have exactly one string label."@en ;
    ] ;
    sh:property [
        sh:path weave:performedBy ;
        sh:name "Performed by" ;
        sh:class weave:Actor ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "A Process must be performed by at least one Actor."@en ;
    ] .

weave:ActivityShape
    a sh:NodeShape ;
    sh:targetClass weave:Activity ;
    sh:property [
        sh:path weave:label ;
        sh:name "Label" ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "Every Activity must have a string label."@en ;
    ] ;
    sh:property [
        sh:path weave:description ;
        sh:name "Description" ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message "An Activity should carry a description."@en ;
    ] .

weave:GoalShape
    a sh:NodeShape ;
    sh:targetClass weave:Goal ;
    sh:property [
        sh:path weave:label ;
        sh:name "Label" ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "Every Goal must have a string label."@en ;
    ] ;
    sh:property [
        sh:path weave:servesGoal ;
        sh:name "Served by capability" ;
        sh:minCount 1 ;
        sh:severity sh:Info ;
        sh:message "Consider linking a BusinessCapability that servesGoal this Goal."@en ;
    ] .

# TASK-004 AC-004-05: remaining 11 BPMO kinds, label-only shapes -- same
# pattern as ProcessShape/ActivityShape/GoalShape's label property. No
# second (relationship/warning/info) property is added for these: nothing
# in this task's scope needs one, and a speculative one would be an
# untested, unenforced guess at each kind's real shape.
weave:EventShape
    a sh:NodeShape ;
    sh:targetClass weave:Event ;
    sh:property [
        sh:path weave:label ;
        sh:name "Label" ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:severity sh:Violation ;
        sh:message "Every Event must have exactly one string label."@en ;
    ] .

