# TASK-011 AC-011-01/-02: plain-language `skos:definition` for every one of
# the 14 BPMO kinds served by CE-READ-1 (`GET /api/ontology/types`), so a
# business modeller can pick the right kind without already knowing the
# BPMO grammar. Sourced field, not a second hand-maintained copy -- see
# `ontology/catalogue.py::_skos_definition`.
weave:Process skos:definition "A repeatable sequence of activities performed to achieve a goal."@en .
weave:Activity skos:definition "A single step of work within a process."@en .
weave:Event skos:definition "Something that happens at a point in time and can trigger or record a change."@en .
weave:DataAsset skos:definition "A named collection of data the business creates, holds, or relies on."@en .
weave:Field skos:definition "A single named attribute within a data asset."@en .
weave:System skos:definition "A software application or platform that performs or supports business activities."@en .
weave:Service skos:definition "A discrete unit of functionality a system exposes to be used by other systems or people."@en .
weave:BusinessCapability skos:definition "Something the business is able to do, independent of how it is currently organised or executed."@en .
weave:BusinessDomain skos:definition "A grouping of related business capabilities under a shared area of responsibility."@en .
weave:Policy skos:definition "A rule or constraint that governs how activities or decisions must be carried out."@en .
weave:Goal skos:definition "A desired outcome that a process or capability exists to serve."@en .
weave:Actor skos:definition "A person, team, role, or external party that performs or is responsible for activities."@en .
weave:Concept skos:definition "A business idea or term defined for shared understanding, not tied to a specific process or system."@en .
weave:Class skos:definition "A category used to classify or group other resources in the graph."@en .

# CE-V1-TASK-001: SKOS glossary term (EPIC-003, decision B1 -- punning).
# targetClass is `skos:Concept` only, never also `owl:Class` -- every
# instance of *any* OWL class would otherwise become a shape target and
# be forced to carry skos:prefLabel/skos:definition (see ADR-022). The
# punning invariant itself (the focus node must ALSO be typed owl:Class)
# is checked as an ordinary property shape below instead.
weave:GlossaryTermShape
    a sh:NodeShape ;
    sh:targetClass skos:Concept ;
    sh:property [
        sh:path rdf:type ;
        sh:name "Punned OWL class type" ;
        sh:hasValue owl:Class ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "A glossary term (skos:Concept) must also be typed owl:Class (punning, decision B1)."@en ;
    ] ;
    sh:property [
        sh:path skos:prefLabel ;
        sh:name "Preferred label" ;
        sh:datatype rdf:langString ;
        sh:uniqueLang true ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "Every glossary term must have exactly one skos:prefLabel per language."@en ;
    ] ;
    sh:property [
        sh:path skos:definition ;
        sh:name "Definition" ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:severity sh:Violation ;
        sh:message "Every glossary term must have exactly one skos:definition."@en ;
    ] ;
    sh:property [
        sh:path skos:broader ;
        sh:name "Broader term" ;
        sh:class skos:Concept ;
        sh:severity sh:Violation ;
        sh:message "A skos:broader target must itself be a glossary term (skos:Concept)."@en ;
    ] ;
    sh:property [
        sh:path skos:narrower ;
        sh:name "Narrower term" ;
        sh:class skos:Concept ;
        sh:severity sh:Violation ;
        sh:message "A skos:narrower target must itself be a glossary term (skos:Concept)."@en ;
    ] .

# TASK-003 (EPIC-004): framework-level classes, not BPMO kinds -- committed
# via CE-WRITE-1 using a full-IRI `kind` (bypasses `authoring/bpmo.py`'s
# 14-kind guard, same convention planned for `weave:Function`). Deliberately
# excluded from `GET /api/ontology/types` -- `ontology/catalogue.py::list_kinds`
# filters to `BPMO_KINDS` membership (ADR-022), so these two shapes still
# validate here without appearing as guided-form kinds.
weave:BrandStandardShape
    a sh:NodeShape ;
    sh:targetClass weave:BrandStandard ;
    sh:property [
        sh:path weave:contentType ;
        sh:name "Content type" ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:severity sh:Violation ;
        sh:message "Every BrandStandard must have exactly one string contentType."@en ;
    ] ;
    sh:property [
        sh:path weave:effectiveDate ;
        sh:name "Effective date" ;
        sh:datatype xsd:date ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:severity sh:Violation ;
        sh:message "Every BrandStandard must have exactly one effectiveDate."@en ;
    ] ;
    sh:property [
        sh:path weave:owner ;
        sh:name "Owner" ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:severity sh:Violation ;
        sh:message "Every BrandStandard must have exactly one owner."@en ;
    ] ;
    sh:or (
        [ sh:property [ sh:path weave:contentBody ; sh:minCount 1 ; ] ]
        [ sh:property [ sh:path weave:sourceUri ; sh:minCount 1 ; ] ]
    ) ;
    sh:severity sh:Violation ;
    sh:message "A BrandStandard must have either a contentBody or a sourceUri."@en .

weave:VoiceRuleShape
    a sh:NodeShape ;
    sh:targetClass weave:VoiceRule ;
    sh:property [
        sh:path weave:ruleId ;
        sh:name "Rule ID" ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:severity sh:Violation ;
        sh:message "Every VoiceRule must have exactly one string ruleId."@en ;
    ] ;
    sh:property [
        sh:path weave:severity ;
        sh:name "Severity" ;
        sh:datatype xsd:string ;
        # explicit ^^xsd:string (not bare "critical") -- rdflib's Turtle
        # parser gives a plain quoted list literal datatype=None, which
        # fails term-equality against `_to_literal`'s explicit
        # Literal(str, datatype=XSD.string) production data (graph_ops.py).
        sh:in ( "critical"^^xsd:string "normal"^^xsd:string ) ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:severity sh:Violation ;
        sh:message "Every VoiceRule must have severity 'critical' or 'normal'."@en ;
    ] ;
    sh:property [
        # AC-003-05: a human label alone is not a rule -- Build mechanically
        # evaluates `assertion`, so it's required, not conventional.
        sh:path weave:assertion ;
        sh:name "Assertion" ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:severity sh:Violation ;
        sh:message "Every VoiceRule must have a machine-evaluable assertion."@en ;
    ] .
