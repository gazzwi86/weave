{
  "weave": {
    "version": "0.1.0",
    "stack": {
      "language": "typescript",
      "framework": "nextjs",
      "package_manager": "npm",
      "test_framework": "vitest",
      "e2e_framework": "playwright",
      "iac": "terraform",
      "cloud_provider": "aws",
      "database": "postgres"
    },
    "linting": {
      "cyclomaticComplexity": 10,
      "cognitiveComplexity": 15
    },
    "git": {
      "commitFormat": "conventional",
      "branchPattern": "feature/{epic}",
      "worktreeIsolation": false,
      "_note": "Tasks within an epic commit sequentially onto one feature/{epic} branch and ship as a single epic PR (a coherent, navigable feature). Per-task worktree isolation is OFF (a branch cannot live in two worktrees, and it would break epic assembly) \u2014 engineer.md/quality-assurance.md no longer self-isolate. Engagement-level isolation is the operator's own git worktree. The prototyper still uses its own per-prototype worktree (separate concern). See .claude/skills/implement CODIFY."
    },
    "brownfield": {
      "scoutThresholds": {
        "totalNodes": 500,
        "topLevelClusters": 6,
        "largestClusterNodes": 150,
        "graphJsonSizeMb": 5
      },
      "freshness": {
        "sessionBannerAgeCommits": 50,
        "ruleStaleDays": 90,
        "shardStaleDays": 180,
        "adrStaleDays": 365
      },
      "coverage": {
        "minPctForDeepArtefacts": 85,
        "supportedLanguagesPath": "${CLAUDE_PLUGIN_ROOT}/templates/supported-languages.yml"
      },
      "claudeMd": {
        "rootLineCap": 60,
        "domainLineCap": 100,
        "ruleLineCap": 60,
        "shardLineCap": 200
      }
    }
  },
  "plansDirectory": "./.claude/plans",
  "advisorModel": "fable",
  "attribution": {
    "commit": "Co-Authored-By: Claude <noreply@anthropic.com>",
    "pr": "Generated with [Claude Code](https://claude.ai/code)"
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/scripts/statusline.sh\"",
    "padding": 0
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "teammateMode": "auto",
    "WEAVE_CAVEMAN": "true"
  },
  "permissions": {
    "allow": [
      "Bash(docker compose *)",
      "Bash(gh api *)",
      "Bash(npm test)",
      "Bash(npm run lint)",
      "Bash(npm run dev)",
      "Bash(node *)",
      "WebSearch",
      "Read",
      "Write",
      "Edit",
      "Bash(git commit *)",
      "Bash(git add *)",
      "Bash(git checkout *)",
      "Bash(git push origin *)"
    ],
    "ask": [],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(curl*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./*.pem)",
      "Read(./*.key)"
    ]
  },
  "_examples": {
    "_why": "A per-edit LLM security-linter hook was removed from always-on config. It fires on every Edit|Write, making it very expensive for routine tasks. Kept here for reference; see also .claude/examples/expensive-hooks.json for embedding instructions. (The claude -p subprocess variant was deleted with modules/claude_review.py \u2014 it duplicated this prompt hook and added a second billable API call per write.)",
    "per-edit-prompt-hook": {
      "_cost": "~2500 tokens injected into the main context window on every Edit|Write call",
      "_why_disabled": "At 2500 tokens/edit this doubles context size on a typical feature branch. Moved to Stop event (single fire per session) instead.",
      "type": "prompt",
      "prompt": "You are a security linter. The hook input JSON below describes a file Claude just wrote. If tool_input.file_path is not under apps/, packages/, infra/, or .claude/scripts/ \u2014 or does not end in .ts, .tsx, .js, .mjs, .py, or .sh \u2014 return {\"decision\":\"approve\"} immediately with no other commentary. Otherwise inspect tool_input.content (Write) or tool_input.new_string (Edit) and decide if it (a) hardcodes a real secret/API key/token (a placeholder or example string in a config file's fallback or .env.example is fine), (b) calls eval() or new Function(), or (c) introduces a clear command/SQL injection. Return JSON ONLY, in the form {\"decision\":\"block\",\"reason\":\"...\"} on a violation, or {\"decision\":\"approve\"} otherwise.\n\nHook input:\n$ARGUMENTS"
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks.py pre-tool-use check-no-secrets",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks.py pre-tool-use check-uv-over-pip",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks.py pre-tool-use check-uv-over-pip",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks.py pre-tool-use check-install-safety",
            "timeout": 15000
          },
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks.py pre-tool-use check-git-safety",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks.py post-tool-use mark-anatomy-stale",
            "timeout": 5000,
            "async": true
          },
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks.py post-tool-use commit-progress",
            "timeout": 10000,
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks.py notification"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks.py user-prompt-submit"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks.py stop"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "rate_limit|billing_error",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks.py stop-failure"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks.py subagent-stop"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks.py pre-compact"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks.py session-start"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks.py session-end"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@anthropic-ai/context7-mcp@latest"
      ]
    },
    "headroom": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "headroom-ai",
        "mcp"
      ]
    }
  }
}