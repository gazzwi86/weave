{
  "plansDirectory": "./.claude/plans",
  "advisorModel": "opus",
  "attribution": {
    "commit": "Co-Authored-By: Claude <noreply@anthropic.com>",
    "pr": "Generated with [Claude Code](https://claude.ai/code)"
  },
  "statusLine": {
    "type": "command",
    "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/scripts/statusline.sh",
    "padding": 0
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "teammateMode": "auto"
  },
  "permissions": {
    "allow": [
      "Bash(docker compose *)",
      "Bash(gh api *)",
      "Bash(npm test)",
      "Bash(npm run lint)",
      "Bash(npm run dev)",
      "Bash(node *)",
      "WebSearch",
      "Read",
      "Write",
      "Edit"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(rm *)",
      "Bash(chmod *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(curl*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./*.pem)",
      "Read(./*.key)"
    ]
  },  
  "_examples": {
    "_why": "Two per-edit LLM hooks were removed from always-on config. Each fires on every Edit|Write, making them very expensive for routine tasks. Moved here for reference; see also .claude/examples/expensive-hooks.json for embedding instructions.",
    "per-edit-prompt-hook": {
      "_cost": "~2500 tokens injected into the main context window on every Edit|Write call",
      "_why_disabled": "At 2500 tokens/edit this doubles context size on a typical feature branch. Moved to Stop event (single fire per session) instead.",
      "type": "prompt",
      "prompt": "You are a security linter. The hook input JSON below describes a file Claude just wrote. If tool_input.file_path is not under apps/, packages/, infra/, or .claude/scripts/ — or does not end in .ts, .tsx, .js, .mjs, .py, or .sh — return {\"decision\":\"approve\"} immediately with no other commentary. Otherwise inspect tool_input.content (Write) or tool_input.new_string (Edit) and decide if it (a) hardcodes a real secret/API key/token (a placeholder or example string in a config file's fallback or .env.example is fine), (b) calls eval() or new Function(), or (c) introduces a clear command/SQL injection. Return JSON ONLY, in the form {\"decision\":\"block\",\"reason\":\"...\"} on a violation, or {\"decision\":\"approve\"} otherwise.\n\nHook input:\n$ARGUMENTS"
    },
    "per-edit-claude-subprocess-hook": {
      "_cost": "Spawns a claude -p subprocess per Edit|Write — a separate API call (+ latency) each time",
      "_why_disabled": "Redundant with the prompt: hook above and creates a second billable API call on every file write. See .claude/examples/expensive-hooks.json for the full working config.",
      "type": "command",
      "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks.py post-tool-use claude-review",
      "timeout": 45000,
      "async": true,
      "statusMessage": "Running claude -p security review"
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks.py pre-tool-use check-no-secrets",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks.py pre-tool-use check-uv-over-pip",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks.py pre-tool-use check-uv-over-pip",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks.py post-tool-use mark-anatomy-stale",
            "timeout": 5000,
            "async": true
          },
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks.py post-tool-use commit-progress",
            "timeout": 10000,
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks.py notification"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks.py user-prompt-submit"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks.py stop"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks.py subagent-stop"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks.py pre-compact"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks.py session-start"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks.py session-end"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@anthropic-ai/context7-mcp@latest"
      ]
    },
    "headroom": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "headroom-ai",
        "mcp"
      ]
    }
  }
}
