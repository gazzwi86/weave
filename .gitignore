# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
out/
.next/
.nuxt/
.output/
# ...except the Build Engine's own `weave_backend.build` package (a real
# Python package, not a build artefact -- the bare `build/` pattern above
# would otherwise silently swallow it).
!packages/backend/src/weave_backend/build/
!packages/backend/src/weave_backend/build/**

# Environment
.env
.env.*
!.env.example

# Secrets / keys
*.pem
*.key
*.p12
*.pfx

# IDE
.DS_Store
*.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Python
__pycache__/
*__pycache__
*.py[cod]
*.pyo
.venv/

# Test / coverage
coverage/
.coverage
.nyc_output/
playwright-report/
test-results/

# Mutation testing (mutmut)
mutants/
.mutmut-cache

# Terraform (state backend is gitignored — never commit real/local state;
# .terraform.lock.hcl IS committed on purpose, it pins provider versions)
.terraform/
*.tfstate
*.tfstate.*
*.tfplan
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Session audit trail (full transcripts — may contain secrets/PII; local-only)
.claude/logs/

# Misc
.turbo/
*.tsbuildinfo

# Weave — raw SME intake staging (scrubbed synthesis promoted to .claude/state/context/)
.claude/_intake/
# Weave — legacy agent configs preserved by init Step 1.5
.legacy/
# Weave — throwaway reference prototypes (deleted once specs are complete; not part of the harness)
prototypes/
# Weave — local file-history archive (engagement worklogs/findings + superseded specs; not committed)
.history/
# Weave — local git worktrees (not committed)
.worktrees/
# Weave — OKF knowledge graph (generated on demand by /okf-visualize or /anatomy; not committed)
docs/viz.html
docs/specs/weave/viz.html
.thinking.md
# Weave — CE-TASK-008 perf-benchmark JSON output (CI artefact, not repo content)
scripts/benchmarks/ce-perf/reports/*.json